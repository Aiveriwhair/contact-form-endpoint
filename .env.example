# =============================================================================
# Server
# =============================================================================

# Port on which the API listens
PORT=3000

# Base URL path for all routes (default: /api/contact)
BASE_URL=/api/contact

# Environment: "development" or "production"
# Controls console logging and rate limiter behavior
NODE_ENV=development

# =============================================================================
# SMTP Transport
# =============================================================================

# SMTP server hostname
EMAIL_HOST=smtp.gmail.com

# SMTP server port (587 = STARTTLS, 465 = TLS)
EMAIL_PORT=587

# Use TLS directly (true for port 465, false for 587 with STARTTLS)
EMAIL_SECURE=false

# SMTP authentication credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# =============================================================================
# Email Settings
# =============================================================================

# Global kill-switch — when false, POST /api/contact/submit returns 200 without sending any email
SEND_EMAILS=false

# Sender address shown in emails
EMAIL_FROM=your-email@gmail.com

# Recipient(s) for contact form submissions (comma-separated)
EMAIL_TO=contact@example.com

# Send an automatic confirmation email to the person who submitted the form
SEND_CONFIRMATION_EMAIL=true

# Company / brand name used in email footers (copyright)
COMPANY_NAME=My Company

# Name shown in email signatures (defaults to COMPANY_NAME if not set)
# SIGNATURE_NAME=Jean Dupont

# =============================================================================
# Internationalization
# =============================================================================

# Default language for user-facing emails when no locale is provided (ISO 639-1)
DEFAULT_LANGUAGE=fr

# Language used for internal notification emails sent to EMAIL_TO (ISO 639-1)
INTERNAL_EMAIL_LANGUAGE=fr

# =============================================================================
# Templates
# =============================================================================

# Absolute path to a custom templates directory (overrides built-in templates)
# Leave empty to use the default templates shipped with the project
# TEMPLATES_DIR=/path/to/custom/templates

# Template engine: "handlebars" (default) or "ejs"
# Templates must use the matching file extension (.hbs or .ejs)
TEMPLATE_ENGINE=handlebars

# Default template name to use when the request does not specify one
# Must match a template file in the templates directory (without locale suffix and extension)
# Available built-in values: default, minimal, detailed
# DEFAULT_TEMPLATE=minimal

# =============================================================================
# CORS
# =============================================================================

# Allowed origins for CORS (comma-separated). Use * to allow all origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
