<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Réponse</title>
    <style>
      body { font-family: 'Helvetica Neue', Arial, sans-serif; line-height: 1.6; color: #2d3436; max-width: 600px; margin: 0 auto; padding: 20px; background: #f0f4f0; }
      .container { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(45, 106, 79, 0.1); }
      .header { background: linear-gradient(135deg, #2d6a4f 0%, #52b788 100%); color: white; padding: 28px; text-align: center; }
      .header h1 { margin: 0; font-size: 20px; font-weight: 600; }
      .header .icon { font-size: 32px; margin-bottom: 6px; }
      .body { padding: 28px; }
      .greeting { font-size: 17px; color: #2d3436; margin-bottom: 16px; }
      .reply-message { color: #2d3436; font-size: 15px; line-height: 1.7; white-space: pre-wrap; }
      .original { margin-top: 24px; padding-top: 20px; border-top: 2px solid #d8e8d8; }
      .original-header { color: #95a5a6; font-size: 13px; margin-bottom: 10px; font-style: italic; }
      .original-text { background: #f8faf8; padding: 16px; border-left: 3px solid #52b788; border-radius: 4px; white-space: pre-wrap; font-size: 14px; color: #555; }
      .signature { margin-top: 28px; padding-top: 18px; border-top: 1px solid #e0e0e0; }
      .signature .company { color: #2d6a4f; font-weight: 700; font-size: 15px; }
      .signature .email { color: #e76f51; text-decoration: none; font-size: 14px; }
      .footer { background: #1b4332; color: #95d5b2; padding: 16px; text-align: center; font-size: 11px; }
      .footer p { margin: 3px 0; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div class="icon">🚲</div>
        <h1>Réponse à votre message</h1>
      </div>
      <div class="body">
        <div class="greeting">Bonjour <strong>{{contactName}}</strong>,</div>
        <div class="reply-message">{{replyMessage}}</div>
        {{#if originalMessage}}
        <div class="original">
          <div class="original-header">Votre message du {{originalDate}} :</div>
          <div class="original-text">{{originalMessage}}</div>
        </div>
        {{/if}}
        <div class="signature">
          <div class="company">{{signatureName}}</div>
          <a class="email" href="mailto:{{companyEmail}}">{{companyEmail}}</a>
        </div>
      </div>
      <div class="footer">
        <p>&copy; {{year}} {{companyName}}</p>
      </div>
    </div>
  </body>
</html>
