<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact</title>
    <style>
      body { font-family: 'Courier New', monospace; line-height: 1.5; color: #2d3436; max-width: 560px; margin: 0 auto; padding: 16px; background: #f0f4f0; }
      .minimal { background: #fff; padding: 24px; border-radius: 8px; border-top: 4px solid #52b788; }
      .title { color: #2d6a4f; font-size: 16px; font-weight: 700; margin-bottom: 16px; }
      .line { margin-bottom: 6px; font-size: 14px; }
      .line strong { color: #2d6a4f; }
      .line a { color: #e76f51; text-decoration: none; }
      .msg { background: #f8faf8; padding: 14px; margin: 12px 0; white-space: pre-wrap; border-left: 3px solid #52b788; font-size: 14px; }
      .ctx { background: #fff8f0; padding: 12px; margin: 12px 0; border-left: 3px solid #f4a261; font-size: 13px; }
      .ts { color: #95a5a6; font-size: 12px; margin-top: 14px; }
    </style>
  </head>
  <body>
    <div class="minimal">
      <div class="title">🚲 Contact</div>
      <div class="line"><strong>Nom :</strong> {{name}}</div>
      <div class="line"><strong>Email :</strong> <a href="mailto:{{email}}">{{email}}</a></div>
      <div class="line"><strong>Sujet :</strong> {{subject}}</div>
      <div class="msg">{{message}}</div>
      {{#if context}}
      <div class="ctx">
        {{#each context}}
        <div><strong>{{@key}} :</strong> {{this}}</div>
        {{/each}}
      </div>
      {{/if}}
      <div class="ts">Reçu le {{timestamp}}</div>
    </div>
  </body>
</html>
