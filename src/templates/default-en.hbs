<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Contact Message</title>
    <style>
      body { font-family: 'Helvetica Neue', Arial, sans-serif; line-height: 1.6; color: #2d3436; max-width: 600px; margin: 0 auto; padding: 20px; background: #f0f4f0; }
      .header { background: linear-gradient(135deg, #2d6a4f 0%, #52b788 100%); color: white; padding: 30px; border-radius: 12px 12px 0 0; text-align: center; }
      .header h1 { margin: 0; font-size: 22px; font-weight: 600; }
      .header .icon { font-size: 36px; margin-bottom: 8px; }
      .content { background: #ffffff; padding: 30px; border-left: 4px solid #52b788; }
      .field { margin-bottom: 18px; }
      .field-label { font-weight: 700; color: #2d6a4f; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
      .field-value { color: #2d3436; font-size: 15px; }
      .field-value a { color: #e76f51; text-decoration: none; }
      .message-box { background: #f8faf8; padding: 18px; border-radius: 6px; margin-top: 8px; white-space: pre-wrap; border: 1px solid #d8e8d8; }
      .context-box { background: #fff8f0; border: 1px solid #f4a261; padding: 15px; border-radius: 6px; margin-top: 10px; }
      .context-title { font-weight: 700; color: #e76f51; margin-bottom: 8px; font-size: 13px; }
      .context-item { padding: 5px 0; border-bottom: 1px solid #fde2c8; font-size: 14px; }
      .context-item:last-child { border-bottom: none; }
      .footer { background: #1b4332; color: #95d5b2; padding: 18px; text-align: center; font-size: 12px; border-radius: 0 0 12px 12px; }
      .footer p { margin: 4px 0; }
    </style>
  </head>
  <body>
    <div class="header">
      <div class="icon">🚲</div>
      <h1>New Contact Message</h1>
    </div>
    <div class="content">
      <div class="field">
        <div class="field-label">Name</div>
        <div class="field-value">{{name}}</div>
      </div>
      <div class="field">
        <div class="field-label">Email</div>
        <div class="field-value"><a href="mailto:{{email}}">{{email}}</a></div>
      </div>
      <div class="field">
        <div class="field-label">Subject</div>
        <div class="field-value">{{subject}}</div>
      </div>
      <div class="field">
        <div class="field-label">Message</div>
        <div class="message-box">{{message}}</div>
      </div>
      {{#if context}}
      <div class="context-box">
        <div class="context-title">Additional Information</div>
        {{#each context}}
        <div class="context-item"><strong>{{@key}}:</strong> {{this}}</div>
        {{/each}}
      </div>
      {{/if}}
    </div>
    <div class="footer">
      <p>Received on {{timestamp}}</p>
      <p>Sent via the contact form</p>
    </div>
  </body>
</html>
